# LLM Provider: ollama | deepseek | openrouter
LLM_PROVIDER=ollama

# Ollama (free testing)
OLLAMA_BASE_URL=http://localhost:11434/v1
OLLAMA_API_KEY=
OLLAMA_MODEL=llama3.2

# DeepSeek (cheap production)
DEEPSEEK_API_KEY=
DEEPSEEK_BASE_URL=https://api.deepseek.com/v1
DEEPSEEK_MODEL=deepseek-chat

# OpenRouter (fallback)
OPENROUTER_API_KEY=
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
OPENROUTER_MODEL=google/gemini-2.0-flash-001

# Rate Limiting
RATE_LIMIT_PER_IP=3/5minutes
RATE_LIMIT_PER_CONVERSATION=12/day

# CORS
CORS_ORIGINS=http://localhost:3000

# PII Allowlist (comma-separated emails/phones that should NOT be redacted)
ALLOWED_EMAILS=
ALLOWED_PHONES=

# Personal Info
PERSONAL_NAME=
PERSONAL_EMAIL=
PERSONAL_GITHUB=
PERSONAL_LINKEDIN=
PERSONAL_TITLE=

# App
LOG_LEVEL=info
