# LLM Provider: ollama | deepseek | openrouter
# "ollama" can serve any model (llama3.2, deepseek-r1, etc.)
# "deepseek" goes directly to DeepSeek's API
LLM_PROVIDER=ollama

# --- Ollama (local or cloud) ---
# Cloud:  https://api.ollama.com/v1   (may need API key)
# Local:  http://localhost:11434/v1    (no key needed)
OLLAMA_BASE_URL=http://localhost:11434/v1
OLLAMA_API_KEY=                       # Optional — only for cloud/authenticated Ollama
OLLAMA_MODEL=ornith:9b                  # Or: deepseek-r1:7b, qwen2.5, mistral, etc.

# --- DeepSeek (direct API — cheap production) ---
DEEPSEEK_API_KEY=
DEEPSEEK_BASE_URL=https://api.deepseek.com/v1
DEEPSEEK_MODEL=deepseek-v4-flash

# --- OpenRouter (fallback) ---
OPENROUTER_API_KEY=
OPENROUTER_MODEL=google/gemini-2.0-flash-001

# --- Rate Limiting ---
RATE_LIMIT_PER_IP=3/minute
RATE_LIMIT_PER_CONVERSATION=12/day

# --- CORS ---
CORS_ORIGINS=http://localhost:3000,https://your-site.pages.dev

# --- Logging ---
LOG_LEVEL=info

# --- Personal Info (used in prompt builder) ---
PERSONAL_NAME=Le Quoc Anh Tran
PERSONAL_EMAIL=lequocanhtr@gmail.com
PERSONAL_GITHUB=https://github.com/Al0ngsy
PERSONAL_LINKEDIN=https://linkedin.com/in/lequocanhtr
PERSONAL_TITLE=Backend Software Engineer
